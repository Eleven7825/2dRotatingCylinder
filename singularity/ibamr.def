Bootstrap: docker
From: ubuntu:22.04

%labels
    Description  IBAMR 3D simulation environment (built with autoibamr)
    IBAMR_VERSION 0.19.0

%environment
    # Activate the autoibamr-installed environment
    if [ -f /opt/ibamr/configuration/enable.sh ]; then
        source /opt/ibamr/configuration/enable.sh
    fi
    export IBAMR_ROOT=/opt/ibamr
    export PATH=/opt/ibamr/bin:$PATH
    export LD_LIBRARY_PATH=/opt/ibamr/lib:$LD_LIBRARY_PATH

%setup
    # Create bind-mount targets BEFORE %post and before any cluster auto-bind.
    # $SINGULARITY_ROOTFS points to the container's root on the host filesystem.
    # NYU Torch/Greene HPC auto-bind targets (from APPTAINER_BINDPATH + common extras)
    for d in scratch scratch1 scratch2 vast projects mnt; do
        mkdir -p "${SINGULARITY_ROOTFS}/${d}"
    done
    mkdir -p "${SINGULARITY_ROOTFS}/state/partition1"
    mkdir -p "${SINGULARITY_ROOTFS}/share/apps"

%post
    export DEBIAN_FRONTEND=noninteractive
    export TZ=UTC

    # ------------------------------------------------------------------ #
    # System packages required by autoibamr and its dependencies
    # ------------------------------------------------------------------ #
    apt-get update -y
    apt-get install -y \
        build-essential \
        gfortran \
        git \
        wget \
        curl \
        python3 \
        python3-distutils \
        python3-dev \
        libopenmpi-dev \
        openmpi-bin \
        liblapack-dev \
        libblas-dev \
        zlib1g-dev \
        libssl-dev \
        libsz2 \
        pkg-config \
        m4 \
        autoconf \
        automake \
        libtool \
        numdiff \
        ca-certificates
    apt-get clean
    rm -rf /var/lib/apt/lists/*

    # ------------------------------------------------------------------ #
    # Build IBAMR and all its dependencies using autoibamr
    # This step takes ~1-3 hours; parallelism is capped at 8 to stay
    # within typical HPC build-node RAM limits.
    # ------------------------------------------------------------------ #
    git clone --depth=1 https://github.com/IBAMR/autoibamr.git /opt/autoibamr-src
    cd /opt/autoibamr-src

    NPROC=$(nproc)
    [ "${NPROC}" -gt 6 ] && NPROC=6

    ./autoibamr.sh \
        --prefix=/opt/ibamr \
        --jobs=${NPROC} \
        --yes \
        --ibamr-version=0.19.0 \
        --disable-numdiff \
        --lapack-library=fblaslapack

    # ------------------------------------------------------------------ #
    # Shrink the image: remove intermediate build artefacts
    # The installed libraries under /opt/ibamr are kept.
    # ------------------------------------------------------------------ #
    rm -rf /opt/autoibamr-src/tmp

%runscript
    exec "$@"

%help
    IBAMR 0.19.0 simulation container built with autoibamr.

    To compile a project against this IBAMR installation:
        apptainer exec ibamr.sif bash -c "
            source /opt/ibamr/configuration/enable.sh
            cmake -DIBAMR_ROOT=/opt/ibamr <source_dir>
            make -j\$(nproc)
        "

    To launch an interactive shell:
        apptainer shell ibamr.sif
